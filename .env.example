# ── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Postgres + pgvector) ───────────────────────────────────
DATABASE_URL=postgresql://shopify_support:shopify_support@localhost:5432/shopify_support
DATABASE_MIGRATE_ON_START=true

# ── LangGraph checkpointer (same Postgres) ───────────────────────────
LANGGRAPH_CHECKPOINT_DB_URL=postgresql://shopify_support:shopify_support@localhost:5432/shopify_support

# ── LLM — Claude / Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM — OpenAI (required for embeddings: memory RAG + app knowledge) ─
# At least one of ANTHROPIC_API_KEY or OPENAI_API_KEY must be set.
# OPENAI_API_KEY is needed for vector embeddings (text-embedding-3-small).
# Without it, memory retrieval and app knowledge RAG are silently skipped.
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── Web search (Tavily) — optional, used by learnApp (Phase C) ────────
# Get a free key at https://tavily.com. Without it, only docUrls/homepage
# are crawled; Tavily web-search step is skipped.
TAVILY_API_KEY=tvly-...

# ── LangSmith (tracing) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=shopify-support-agent

# ── Secrets encryption key (AES-256-GCM, hex 32 bytes = 64 hex chars)─
ENCRYPTION_KEY=change_me_to_64_hex_chars_0000000000000000000000000000000000000

# ── Playwright ───────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true

# ── Agent workspace (local clone dir) ────────────────────────────────
WORKSPACE_DIR=./workspace

FIRECRAWL_API_KEY=