{
    "name": "shopify-support-agent",
    "version": "0.1.0",
    "private": true,
    "description": "Shopify Embedded App — Super Support Agent monorepo",
    "type": "module",
    "packageManager": "pnpm@10.8.1",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "turbo dev --ui=stream",
        "dev:server": "pnpm --filter @shopify-support/server dev",
        "dev:web": "pnpm --filter @shopify-support/web dev",
        "build": "turbo build",
        "typecheck": "turbo typecheck",
        "lint": "turbo lint",
        "format": "prettier --write .",
        "db:migrate": "pnpm --filter @shopify-support/server db:migrate"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/node": "^22.0.0",
        "eslint": "^9.0.0",
        "globals": "^16.0.0",
        "prettier": "^3.0.0",
        "turbo": "^2.0.0",
        "typescript": "~5.7.0",
        "typescript-eslint": "^8.0.0"
    }
}
